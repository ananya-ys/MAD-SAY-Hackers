# AutoFix AI — Environment Configuration
# Copy to .env and fill in values

# App
APP_ENV=development  # development | staging | production
SECRET_KEY=8162980d3c887b17f74feca623dc6ba198a6f6d2aa546e4f3204a95a9b5e29c1
DEBUG=true

# Database — use SQLite for dev, PostgreSQL for staging/prod
DATABASE_URL=postgresql+asyncpg://autofix:autofix@db:5432/autofix
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/autofix

# LLM
ANTHROPIC_API_KEY=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
LLM_MODEL=qwen/qwen-2.5-coder-32b-instruct:free
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MAX_TOKENS=4096
LLM_CIRCUIT_BREAKER_THRESHOLD=3  # consecutive failures before OPEN

# Rate limits
RATE_LIMIT_USER_PER_MIN=10
RATE_LIMIT_ORG_PER_MIN=100

# Repair engine
DEFAULT_MAX_ITERATIONS=5
DEFAULT_VALIDATION_LEVEL=BASIC  # BASIC | ENDPOINT | TESTS
SANDBOX_TIMEOUT_SECONDS=30
MAX_CONCURRENT_SANDBOXES=50
STACK_TRACE_MAX_BYTES=51200  # 50KB

# Cache (in-process TTLCache — no Redis at MVP)
L1_CACHE_MAXSIZE=1000
L1_CACHE_TTL_SECONDS=3600

# Confidence thresholds
CONFIDENCE_AUTO_USE=0.80
CONFIDENCE_WARN=0.60
CONFIDENCE_EVICTION=0.20
CONFIDENCE_SRE_ALERT=0.50

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Observability
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=  # leave empty to disable

# Wiki
WIKI_DIR=debug_wiki/errors
